  <description>
    Prototype XML export for the Shell garage coffee quality-control dashboard. Scores use fake data and are stored as decimal rates where 0.90 equals 90%.
  </description>

  <survey>
    <urlPattern>/?view=survey&amp;branch_id={branch_id}</urlPattern>
    <requiresLogin>false</requiresLogin>
    <storageMode>local_state_or_mock_data</storageMode>
    <questions>
      <question id="q1" categoryKey="coffee_quality_score" type="yes_no" required="true">Was your coffee enjoyable?</question>
      <question id="q2" categoryKey="speed_score" type="yes_no" required="true">Were you served quickly enough?</question>
      <question id="q3" categoryKey="staff_service_score" type="yes_no" required="true">Was the staff friendly and helpful?</question>
      <question id="q4" categoryKey="cleanliness_score" type="yes_no" required="true">Was the coffee area clean and comfortable?</question>
      <question id="q5" categoryKey="buy_again" type="yes_no" required="false">Would you buy coffee from this Shell again?</question>
      <commentBox required="false" recommendedWhenAnyAnswerIsNo="true" />
    </questions>
  </survey>

  <scoringLogic>
    <answer value="yes" numericValue="1" />
    <answer value="no" numericValue="0" />
    <categoryScore formula="yes_responses / total_responses" />
    <overallScore formula="average(coffee_quality_score, speed_score, staff_service_score, cleanliness_score)" />
  </scoringLogic>

  <thresholds>
    <status name="Excellent" rule="overall_score &gt;= 0.90" />
    <status name="Healthy" rule="overall_score &gt;= 0.80 and overall_score &lt; 0.90" />
    <status name="Watchlist" rule="overall_score &gt;= 0.70 and overall_score &lt; 0.80" />
    <status name="Intervention Required" rule="overall_score &lt; 0.70" />
    <flag name="Low Confidence" rule="monthly_response_count &lt; 30" />
    <flag name="Critical Category" rule="any category score &lt; 0.65" />
  </thresholds>

  <outlierLogic>
    <boxAndWhisker q1="25th_percentile" q3="75th_percentile" iqr="q3 - q1" />
    <topOutlier rule="score &gt; q3 + 1.5 * iqr" marker="star" />
    <bottomOutlier rule="score &lt; q1 - 1.5 * iqr" marker="cross" />
    <normalPoint marker="circle" />
  </outlierLogic>

